# Journey Bot Configuration Settings

# Discord configuration
DISCORD_TOKEN=your_bot_token_here
# Optional: Guild ID for immediate slash command sync during development.
# If omitted, commands are synced globally (which can take up to an hour).
TEST_GUILD_ID=123456789012345678

# Database configuration
# Asyncpg driver is required for the bot's asynchronous queries
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/journey_db
# Sync driver connection is used by Alembic migrations
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/journey_db

# Cache/Redis configuration
# If left blank, the bot will automatically fall back to an in-memory cache
REDIS_URL=redis://localhost:6379/0

# App Settings
LOG_LEVEL=INFO
